# ─────────────────────────────────────────────────────────────
#  MAIL MISSION — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to GitHub.
# ─────────────────────────────────────────────────────────────

# Google OAuth2 Credentials
# Get these from: https://console.cloud.google.com
# Create a project → Enable Gmail API → OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The URL Google redirects to after login
# Local development:
REDIRECT_URI=http://localhost:3000/auth/callback
# Production (replace with your real domain):
# REDIRECT_URI=https://yourdomain.com/auth/callback

# Gemini API Key (free — no card needed)
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Session secret — change this to any long random string
SESSION_SECRET=change_this_to_a_long_random_string_like_abc123xyz

# Port (optional, defaults to 3000)
PORT=3000
